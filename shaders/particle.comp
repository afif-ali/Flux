#version 460 core
layout(local_size_x = 256) in;

struct Particle
{
    vec2 position;
};

layout(std430, binding = 0) buffer ParticleBuffer
{
    Particle particles[];
};

void main()
{
    uint id = gl_GlobalInvocationID.x;
    if (id >= particles.length())
        return;

    particles[id].position.y -= 0.0001;

    if(particles[id].position.y < -1.0)
        particles[id].position.y = 1.;
}